<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BuildForce.Views.EstimateCreatePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#eef1f8">

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,40" Spacing="12">

            <Border BackgroundColor="White" Stroke="Transparent"
                    StrokeShape="RoundRectangle 16" Padding="0">
                <Border.Shadow>
                    <Shadow Brush="#1a2340" Offset="0,2" Radius="10" Opacity="0.08" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">
                    <Grid HeightRequest="5">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#f0a500" Offset="0.0" />
                                <GradientStop Color="#0ea5e9" Offset="0.5" />
                                <GradientStop Color="#10b981" Offset="1.0" />
                            </LinearGradientBrush>
                        </Grid.Background>
                    </Grid>
                    <VerticalStackLayout Padding="18,14,18,16" Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="SALES  &#x203A;  ESTIMATES"
                                   FontSize="10" FontAttributes="Bold"
                                   TextColor="#8a93a8" CharacterSpacing="2"
                                   VerticalOptions="Center" />
                            <Border Grid.Column="1"
                                    BackgroundColor="#eef1f8" Stroke="#d8deeb" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 18" Padding="12,6">
                                <Label Text="Cancel" FontSize="12" FontAttributes="Bold"
                                       TextColor="#1a2340" />
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCancel" />
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                        <Label Text="Create New Estimate"
                               FontSize="22" FontAttributes="Bold" TextColor="#1a2340" />
                        <Label Text="Quote a customer for work on a project"
                               FontSize="12" TextColor="#6b7280" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Stroke="#e2e7f0" StrokeThickness="1"
                    StrokeShape="RoundRectangle 14" Padding="16,14">
                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="6">
                        <Label Text="PROJECT *" FontSize="10" FontAttributes="Bold"
                               TextColor="#8a93a8" CharacterSpacing="1" />
                        <Border BackgroundColor="White" Stroke="#d8deeb" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10" Padding="6,0">
                            <Picker x:Name="ProjectPicker" Title="&#8212; Select Project &#8212;"
                                    TextColor="#1a2340" TitleColor="#9aa3b8"
                                    BackgroundColor="Transparent" Margin="8,0" />
                        </Border>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6" Grid.Column="0">
                            <Label Text="ESTIMATE DATE" FontSize="10" FontAttributes="Bold"
                                   TextColor="#8a93a8" CharacterSpacing="1" />
                            <Border BackgroundColor="White" Stroke="#d8deeb" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10" Padding="12,2">
                                <DatePicker x:Name="EstimateDatePicker" TextColor="#1a2340"
                                            BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="6" Grid.Column="1">
                            <Label Text="VALID UNTIL" FontSize="10" FontAttributes="Bold"
                                   TextColor="#8a93a8" CharacterSpacing="1" />
                            <Border BackgroundColor="White" Stroke="#d8deeb" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10" Padding="12,2">
                                <DatePicker x:Name="ValidUntilPicker" TextColor="#1a2340"
                                            BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Stroke="#e2e7f0" StrokeThickness="1"
                    StrokeShape="RoundRectangle 14" Padding="16,14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="LINE ITEMS *" FontSize="10" FontAttributes="Bold"
                           TextColor="#8a93a8" CharacterSpacing="1" />
                    <VerticalStackLayout x:Name="LineItemsList" Spacing="10" />
                    <Border BackgroundColor="White" Stroke="#0ea5e9" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 10" Padding="0,11">
                        <Label Text="+ Add Line Item" FontSize="13" FontAttributes="Bold"
                               TextColor="#0284c7" HorizontalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAddLineItem" />
                        </Border.GestureRecognizers>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Stroke="#e2e7f0" StrokeThickness="1"
                    StrokeShape="RoundRectangle 14" Padding="16,14">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="DISCOUNT %" FontSize="10" FontAttributes="Bold"
                               TextColor="#8a93a8" CharacterSpacing="1" />
                        <Border BackgroundColor="White" Stroke="#d8deeb" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10" Padding="12,2">
                            <Entry x:Name="DiscountEntry" Placeholder="0"
                                   Keyboard="Numeric" PlaceholderColor="#9aa3b8"
                                   TextColor="#1a2340" BackgroundColor="Transparent"
                                   TextChanged="OnDiscountChanged" />
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="NOTES" FontSize="10" FontAttributes="Bold"
                               TextColor="#8a93a8" CharacterSpacing="1" />
                        <Border BackgroundColor="White" Stroke="#d8deeb" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10" Padding="12,8">
                            <Editor x:Name="NotesEditor" Placeholder="Optional notes..."
                                    PlaceholderColor="#9aa3b8" TextColor="#1a2340"
                                    BackgroundColor="Transparent"
                                    MinimumHeightRequest="64" AutoSize="TextChanges" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Stroke="#e2e7f0" StrokeThickness="1"
                    StrokeShape="RoundRectangle 14" Padding="16,14">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Subtotal" FontSize="13" TextColor="#6b7280" />
                        <Label x:Name="SubtotalLabel" Text="$0.00" FontSize="13"
                               TextColor="#1a2340" Grid.Column="1" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Discount" FontSize="13" TextColor="#6b7280" />
                        <Label x:Name="DiscountLabel" Text="-$0.00" FontSize="13"
                               TextColor="#b45309" Grid.Column="1" />
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#e2e7f0" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total before tax" FontSize="14" FontAttributes="Bold"
                               TextColor="#1a2340" />
                        <Label x:Name="TotalLabel" Text="$0.00" FontSize="17" FontAttributes="Bold"
                               TextColor="#0d7a4f" Grid.Column="1" />
                    </Grid>
                    <Label Text="Sales tax is added automatically from your company settings when the estimate is saved."
                           FontSize="11" TextColor="#8a93a8" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="StatusLabel" Text="" FontSize="12"
                   TextColor="#b45309" HorizontalOptions="Center" IsVisible="False" />

            <Border x:Name="SaveBtn" BackgroundColor="#f0a500" Stroke="Transparent"
                    StrokeShape="RoundRectangle 12" Padding="0,15">
                <Border.Shadow>
                    <Shadow Brush="#f0a500" Offset="0,4" Radius="12" Opacity="0.3" />
                </Border.Shadow>
                <Label Text="Create Estimate" FontSize="15" FontAttributes="Bold"
                       TextColor="#1a1a1a" HorizontalOptions="Center" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSave" />
                </Border.GestureRecognizers>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>