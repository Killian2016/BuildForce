<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:BuildForce.Views"
             x:Class="BuildForce.Views.MainShellPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#eef1f8">

    <Grid RowDefinitions="*, Auto">

        <!-- Page Content Area -->
        <ContentView x:Name="PageContent" Grid.Row="0" />

        <!-- Native Bottom Dock (plain grid: no clipping of the raised GPS button) -->
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto" BackgroundColor="Transparent">
            <BoxView Grid.Row="0" HeightRequest="1" BackgroundColor="#e2e7f0" />
            <Grid Grid.Row="1" BackgroundColor="White" Padding="0,8,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="76" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Home (whole column tappable) -->
                <VerticalStackLayout x:Name="TabHome" Grid.Column="0" Spacing="3"
                                     HorizontalOptions="Fill" VerticalOptions="Center"
                                     Padding="0,4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="NavHome_Tapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label x:Name="IcoHome" Text="&#x2302;" FontSize="24"
                           TextColor="#f0a500" HorizontalOptions="Center" InputTransparent="True" />
                    <Label x:Name="LblHome" Text="Home" FontSize="9" FontAttributes="Bold"
                           TextColor="#f0a500" HorizontalOptions="Center" CharacterSpacing="0.5"
                           InputTransparent="True" />
                </VerticalStackLayout>

                <!-- Projects -->
                <VerticalStackLayout x:Name="TabProjects" Grid.Column="1" Spacing="3"
                                     HorizontalOptions="Fill" VerticalOptions="Center"
                                     Padding="0,4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="NavProjects_Tapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label x:Name="IcoProjects" Text="&#x25A6;" FontSize="22"
                           TextColor="#8a93a8" HorizontalOptions="Center" InputTransparent="True" />
                    <Label x:Name="LblProjects" Text="Projects" FontSize="9" FontAttributes="Bold"
                           TextColor="#8a93a8" HorizontalOptions="Center" CharacterSpacing="0.5"
                           InputTransparent="True" />
                </VerticalStackLayout>

                <!-- GPS Clock (inside dock flow: no clipping) -->
                <VerticalStackLayout Grid.Column="2" Spacing="3"
                                     HorizontalOptions="Center" VerticalOptions="Center">
                    <Border x:Name="ClockBtn"
                            BackgroundColor="#f0a500"
                            StrokeShape="RoundRectangle 26"
                            WidthRequest="52" HeightRequest="52"
                            Stroke="Transparent"
                            HorizontalOptions="Center">
                        <Border.Shadow>
                            <Shadow Brush="#f0a500" Offset="0,4" Radius="12" Opacity="0.4" />
                        </Border.Shadow>
                        <Label x:Name="ClockLabel"
                               Text="GPS" FontSize="12" FontAttributes="Bold"
                               TextColor="#1a1a1a"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               InputTransparent="True" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="NavClock_Tapped" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Label x:Name="LblClock" Text="Clock" FontSize="9" FontAttributes="Bold"
                           TextColor="#b57c00" HorizontalOptions="Center" CharacterSpacing="0.5" />
                </VerticalStackLayout>

                <!-- Invoices -->
                <VerticalStackLayout x:Name="TabInvoices" Grid.Column="3" Spacing="3"
                                     HorizontalOptions="Fill" VerticalOptions="Center"
                                     Padding="0,4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="NavInvoices_Tapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label x:Name="IcoInvoices" Text="&#x0024;" FontSize="22" FontAttributes="Bold"
                           TextColor="#8a93a8" HorizontalOptions="Center" InputTransparent="True" />
                    <Label x:Name="LblInvoices" Text="Invoices" FontSize="9" FontAttributes="Bold"
                           TextColor="#8a93a8" HorizontalOptions="Center" CharacterSpacing="0.5"
                           InputTransparent="True" />
                </VerticalStackLayout>

                <!-- More -->
                <VerticalStackLayout x:Name="TabMore" Grid.Column="4" Spacing="3"
                                     HorizontalOptions="Fill" VerticalOptions="Center"
                                     Padding="0,4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="NavMore_Tapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label x:Name="IcoMore" Text="&#x2630;" FontSize="22"
                           TextColor="#8a93a8" HorizontalOptions="Center" InputTransparent="True" />
                    <Label x:Name="LblMore" Text="More" FontSize="9" FontAttributes="Bold"
                           TextColor="#8a93a8" HorizontalOptions="Center" CharacterSpacing="0.5"
                           InputTransparent="True" />
                </VerticalStackLayout>

            </Grid>
        </Grid>
    </Grid>
</ContentPage>