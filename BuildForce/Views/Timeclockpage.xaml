<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BuildForce.Views.TimeClockPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0a1628">

    <ScrollView>
        <VerticalStackLayout Padding="16,20,16,100" Spacing="14">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <Label Text="TIME CLOCK"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="#6b7280" CharacterSpacing="2"
                       VerticalOptions="Center" />
                <Border x:Name="ClockedInBadge"
                        BackgroundColor="#0d2e1a"
                        Stroke="#22c55e" StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="10,5"
                        Grid.Column="1"
                        IsVisible="False">
                    <Label Text="LIVE" FontSize="10"
                           FontAttributes="Bold" TextColor="#22c55e" />
                </Border>
            </Grid>

            <!-- Employee Card -->
            <Border BackgroundColor="#111f38"
                    Stroke="#1e3a5f" StrokeThickness="1"
                    StrokeShape="RoundRectangle 14"
                    Padding="14,12">
                <Grid ColumnDefinitions="Auto,*">
                    <Border BackgroundColor="#1e3a5f"
                            StrokeShape="RoundRectangle 22"
                            Stroke="Transparent"
                            WidthRequest="44" HeightRequest="44">
                        <Label Text="👷" FontSize="22"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0"
                                        Spacing="2" VerticalOptions="Center">
                        <Label x:Name="EmployeeNameLabel"
                               Text="Loading..."
                               FontSize="15" FontAttributes="Bold"
                               TextColor="White" />
                        <Label Text="Field Employee"
                               FontSize="11" TextColor="#6b7280" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Project Picker -->
            <Border BackgroundColor="#111f38"
                    Stroke="#1e3a5f" StrokeThickness="1"
                    StrokeShape="RoundRectangle 14"
                    Padding="4,0">
                <Grid ColumnDefinitions="Auto,*">
                    <Label Text="🏗" FontSize="16"
                           Margin="14,0,0,0"
                           VerticalOptions="Center" />
                    <Picker x:Name="ProjectPicker"
                            Title="Select Project"
                            TextColor="White"
                            TitleColor="#6b7280"
                            BackgroundColor="Transparent"
                            Grid.Column="1"
                            Margin="4,0" />
                </Grid>
            </Border>

            <!-- Cost Code Picker -->
            <Border BackgroundColor="#111f38"
                    Stroke="#1e3a5f" StrokeThickness="1"
                    StrokeShape="RoundRectangle 14"
                    Padding="4,0">
                <Grid ColumnDefinitions="Auto,*">
                    <Label Text="Cost Code:"
                           FontSize="13" TextColor="#6b7280"
                           Margin="14,0,0,0"
                           VerticalOptions="Center" />
                    <Picker x:Name="CostCodePicker"
                            Title="Select..."
                            TextColor="White"
                            TitleColor="#6b7280"
                            BackgroundColor="Transparent"
                            Grid.Column="1"
                            Margin="4,0" />
                </Grid>
            </Border>

            <!-- GPS + Geofence Pills Row -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Border x:Name="LocationPill"
                        BackgroundColor="#0d1f38"
                        Stroke="#1e3a5f" StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="10,6"
                        IsVisible="False">
                    <Label x:Name="LocationLabel"
                           Text="Getting GPS..."
                           FontSize="10" TextColor="#22c55e"
                           HorizontalOptions="Center" />
                </Border>
                <Border x:Name="GeofencePill"
                        BackgroundColor="#0d1f38"
                        Stroke="#1e3a5f" StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="10,6"
                        IsVisible="False"
                        Grid.Column="1">
                    <Label x:Name="GeofenceLabel"
                           Text="Checking..."
                           FontSize="10" TextColor="#f59e0b"
                           HorizontalOptions="Center" />
                </Border>
            </Grid>

            <!-- Retry Location Button -->
            <Button x:Name="RetryLocationBtn"
                    Text="🔄 Retry Location Check"
                    BackgroundColor="#1e3a5f"
                    TextColor="White"
                    FontSize="12"
                    HeightRequest="40"
                    CornerRadius="10"
                    IsVisible="False"
                    Clicked="OnRetryLocation" />

            <!-- Main Timer Card -->
            <Border BackgroundColor="#111f38"
                    Stroke="#1e3a5f" StrokeThickness="1"
                    StrokeShape="RoundRectangle 20"
                    Padding="20,24">
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">

                    <Label x:Name="StatusLabel"
                           Text="NOT CLOCKED IN"
                           FontSize="12" FontAttributes="Bold"
                           TextColor="#6b7280"
                           CharacterSpacing="1"
                           HorizontalOptions="Center" />

                    <Label x:Name="TimerLabel"
                           Text="00:00:00"
                           FontSize="52" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />

                    <!-- Clock In Button -->
                    <Button x:Name="ClockInBtn"
                            Text="Clock In"
                            BackgroundColor="#374151"
                            TextColor="#6b7280"
                            FontSize="16" FontAttributes="Bold"
                            HeightRequest="54"
                            CornerRadius="14"
                            IsEnabled="False"
                            Margin="0,4,0,0"
                            Clicked="OnClockIn" />

                    <!-- Clock Out Button -->
                    <Button x:Name="ClockOutBtn"
                            Text="Clock Out"
                            BackgroundColor="#ef4444"
                            TextColor="White"
                            FontSize="16" FontAttributes="Bold"
                            HeightRequest="54"
                            CornerRadius="14"
                            IsVisible="False"
                            Margin="0,4,0,0"
                            Clicked="OnClockOut" />

                </VerticalStackLayout>
            </Border>

            <!-- Summary Bar -->
            <Border BackgroundColor="#111f38"
                    Stroke="#1e3a5f" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="18,14">
                <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" RowSpacing="4">
                    <Label Text="TODAY" Grid.Column="0"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="#6b7280" CharacterSpacing="1" />
                    <Label Text="THIS WEEK" Grid.Column="1"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="#6b7280" CharacterSpacing="1" />
                    <Label Text="COST CODE" Grid.Column="2"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="#6b7280" CharacterSpacing="1" />
                    <Label x:Name="TodayHoursLabel"
                           Text="0.0h" Grid.Row="1" Grid.Column="0"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="White" />
                    <Label x:Name="WeekHoursLabel"
                           Text="0.0h" Grid.Row="1" Grid.Column="1"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="White" />
                    <Label x:Name="ActiveCostCodeLabel"
                           Text="None" Grid.Row="1" Grid.Column="2"
                           FontSize="15" FontAttributes="Bold"
                           TextColor="#c8e63c" />
                </Grid>
            </Border>

            <!-- Recent Entries -->
            <Label Text="RECENT ENTRIES"
                   FontSize="10" FontAttributes="Bold"
                   TextColor="#6b7280" CharacterSpacing="2"
                   Margin="4,6,0,0" />

            <VerticalStackLayout x:Name="HistoryList" Spacing="8" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
