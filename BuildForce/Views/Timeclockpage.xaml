<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BuildForce.Views.TimeClockPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#eef1f8">

    <Grid RowDefinitions="4,*">

        <!-- Gradient stripe -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*,*">
            <BoxView Color="#f0a500" />
            <BoxView Color="#0ea5e9" Grid.Column="1" />
            <BoxView Color="#10b981" Grid.Column="2" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,16,16,100" Spacing="14">

                <!-- Breadcrumb + live badge -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="FIELD &#x203A; TIME CLOCK"
                           FontSize="11" FontAttributes="Bold"
                           TextColor="#64748b" CharacterSpacing="2"
                           VerticalOptions="Center" />
                    <Border x:Name="ClockedInBadge"
                            BackgroundColor="#e7f8f1"
                            Stroke="#10b981" StrokeThickness="1"
                            StrokeShape="RoundRectangle 20"
                            Padding="10,4"
                            Grid.Column="1"
                            IsVisible="False">
                        <Label Text="LIVE" FontSize="10"
                               FontAttributes="Bold" TextColor="#10b981" />
                    </Border>
                </Grid>

                <!-- Employee card -->
                <Border BackgroundColor="White"
                        Stroke="#e2e8f0" StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="14,12">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border BackgroundColor="#fdf3dd"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 22"
                                WidthRequest="44" HeightRequest="44">
                            <Label x:Name="AvatarLabel" Text="--"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="#f0a500"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0"
                                             Spacing="2" VerticalOptions="Center">
                            <Label x:Name="EmployeeNameLabel"
                                   Text="Loading..."
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="#1a2233" />
                            <Label x:Name="NowDateLabel"
                                   Text=""
                                   FontSize="11" TextColor="#64748b" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Timer card with progress ring -->
                <Border BackgroundColor="White"
                        Stroke="#e2e8f0" StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="18,22">
                    <VerticalStackLayout Spacing="14" HorizontalOptions="Center">

                        <Label x:Name="StatusLabel"
                               Text="NOT CLOCKED IN"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="#64748b"
                               CharacterSpacing="1"
                               HorizontalOptions="Center" />

                        <Grid WidthRequest="230" HeightRequest="230"
                              HorizontalOptions="Center">
                            <GraphicsView x:Name="RingView"
                                          WidthRequest="230" HeightRequest="230" />
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 Spacing="3">
                                <Label x:Name="TimerLabel"
                                       Text="00:00:00"
                                       FontSize="34" FontAttributes="Bold"
                                       TextColor="#1a2233"
                                       HorizontalOptions="Center" />
                                <Label Text="SHIFT ELAPSED"
                                       FontSize="9" FontAttributes="Bold"
                                       TextColor="#94a3b8" CharacterSpacing="2"
                                       HorizontalOptions="Center" />
                                <Border x:Name="StatusChip"
                                        BackgroundColor="#eef1f8"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 20"
                                        Padding="12,4"
                                        HorizontalOptions="Center"
                                        Margin="0,6,0,0">
                                    <Label x:Name="StatusChipLabel"
                                           Text="CLOCKED OUT"
                                           FontSize="10" FontAttributes="Bold"
                                           TextColor="#64748b"
                                           CharacterSpacing="1" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Buttons -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8"
                              WidthRequest="320">
                            <Button x:Name="ClockInBtn"
                                    Text="Clock In"
                                    BackgroundColor="#cbd5e1"
                                    TextColor="#64748b"
                                    FontSize="14" FontAttributes="Bold"
                                    HeightRequest="52"
                                    CornerRadius="12"
                                    IsEnabled="False"
                                    Clicked="OnClockIn" />
                            <Button x:Name="BreakBtn"
                                    Text="Break"
                                    BackgroundColor="White"
                                    TextColor="#94a3b8"
                                    BorderColor="#e2e8f0"
                                    BorderWidth="1"
                                    FontSize="14" FontAttributes="Bold"
                                    HeightRequest="52"
                                    CornerRadius="12"
                                    IsEnabled="False"
                                    Grid.Column="1"
                                    Clicked="OnBreak" />
                            <Button x:Name="ClockOutBtn"
                                    Text="Clock Out"
                                    BackgroundColor="#fca5a5"
                                    TextColor="White"
                                    FontSize="14" FontAttributes="Bold"
                                    HeightRequest="52"
                                    CornerRadius="12"
                                    IsEnabled="False"
                                    Grid.Column="2"
                                    Clicked="OnClockOut" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Project picker -->
                <Border BackgroundColor="White"
                        Stroke="#e2e8f0" StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="14,4">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="PROJECT"
                               FontSize="9" FontAttributes="Bold"
                               TextColor="#94a3b8" CharacterSpacing="2"
                               Margin="0,8,0,0" />
                        <Picker x:Name="ProjectPicker"
                                Title="Select Project"
                                TextColor="#1a2233"
                                TitleColor="#94a3b8"
                                BackgroundColor="Transparent" />
                    </VerticalStackLayout>
                </Border>

                <!-- Cost code picker -->
                <Border BackgroundColor="White"
                        Stroke="#e2e8f0" StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="14,4">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="COST CODE"
                               FontSize="9" FontAttributes="Bold"
                               TextColor="#94a3b8" CharacterSpacing="2"
                               Margin="0,8,0,0" />
                        <Picker x:Name="CostCodePicker"
                                Title="Select..."
                                TextColor="#1a2233"
                                TitleColor="#94a3b8"
                                BackgroundColor="Transparent" />
                    </VerticalStackLayout>
                </Border>

                <!-- GPS / geofence card -->
                <Border BackgroundColor="White"
                        Stroke="#e2e8f0" StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="14,12">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="SITE GEOFENCE"
                               FontSize="9" FontAttributes="Bold"
                               TextColor="#94a3b8" CharacterSpacing="2" />
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border x:Name="GeoIconBox"
                                    BackgroundColor="#fdf3dd"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 10"
                                    WidthRequest="40" HeightRequest="40">
                                <Label x:Name="GeoIconLabel" Text="&#x25CE;"
                                       FontSize="18" TextColor="#f0a500"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2"
                                                 VerticalOptions="Center">
                                <Label x:Name="GeofenceLabel"
                                       Text="Waiting for GPS..."
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#f0a500" />
                                <Label x:Name="LocationLabel"
                                       Text="Getting location..."
                                       FontSize="11" TextColor="#64748b" />
                            </VerticalStackLayout>
                        </Grid>
                        <Button x:Name="RetryLocationBtn"
                                Text="Retry Location Check"
                                BackgroundColor="#eef1f8"
                                TextColor="#1a2233"
                                FontSize="12"
                                HeightRequest="38"
                                CornerRadius="10"
                                IsVisible="False"
                                Clicked="OnRetryLocation" />
                    </VerticalStackLayout>
                </Border>

                <!-- Stats card -->
                <Border BackgroundColor="White"
                        Stroke="#e2e8f0" StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="16,14">
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="4">
                        <Label Text="TODAY"
                               FontSize="9" FontAttributes="Bold"
                               TextColor="#94a3b8" CharacterSpacing="1" />
                        <Label Text="THIS WEEK" Grid.Column="1"
                               FontSize="9" FontAttributes="Bold"
                               TextColor="#94a3b8" CharacterSpacing="1" />
                        <Label Text="BREAK" Grid.Column="2"
                               FontSize="9" FontAttributes="Bold"
                               TextColor="#94a3b8" CharacterSpacing="1" />
                        <Label x:Name="TodayHoursLabel"
                               Text="0.0h" Grid.Row="1"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="#10b981" />
                        <Label x:Name="WeekHoursLabel"
                               Text="0.0h" Grid.Row="1" Grid.Column="1"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="#0ea5e9" />
                        <Label x:Name="BreakTotalLabel"
                               Text="0m" Grid.Row="1" Grid.Column="2"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="#f0a500" />
                        <Label x:Name="ActiveCostCodeLabel"
                               Text="Cost code: none" Grid.Row="2" Grid.ColumnSpan="3"
                               FontSize="11" TextColor="#64748b"
                               Margin="0,4,0,0" />
                    </Grid>
                </Border>

                <!-- Week bars -->
                <Border BackgroundColor="White"
                        Stroke="#e2e8f0" StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="16,14">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="THIS WEEK BY DAY"
                               FontSize="9" FontAttributes="Bold"
                               TextColor="#94a3b8" CharacterSpacing="2" />
                        <Grid x:Name="WeekBarsGrid" HeightRequest="100"
                              ColumnSpacing="8" />
                    </VerticalStackLayout>
                </Border>

                <!-- Recent entries -->
                <Label Text="RECENT ENTRIES"
                       FontSize="10" FontAttributes="Bold"
                       TextColor="#64748b" CharacterSpacing="2"
                       Margin="4,6,0,0" />

                <VerticalStackLayout x:Name="HistoryList" Spacing="8" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>