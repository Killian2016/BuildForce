<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BuildForce.Views.InvoicesPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0a1628">

    <Grid RowDefinitions="Auto, *">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="16,16,16,0" Spacing="12">
            <Label Text="Invoices"
                   FontSize="22" FontAttributes="Bold" TextColor="White" />

            <!-- Search -->
            <Border BackgroundColor="#111f38" Stroke="#1e3a5f"
                    StrokeShape="RoundRectangle 14" Padding="16,12">
                <Label Text="🔍  Search invoices..."
                       FontSize="13" TextColor="#6b7280" />
            </Border>

            <!-- Filter Tabs -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8" Padding="0,0,0,12">
                    <Border x:Name="TabAll" BackgroundColor="#1a2e14"
                            Stroke="#c8e63c" StrokeThickness="1"
                            StrokeShape="RoundRectangle 20" Padding="14,6">
                        <Label Text="All" FontSize="12" FontAttributes="Bold" TextColor="#c8e63c">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFilterAll" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                    <Border x:Name="TabPaid" BackgroundColor="#111f38"
                            Stroke="#1e3a5f" StrokeThickness="1"
                            StrokeShape="RoundRectangle 20" Padding="14,6">
                        <Label Text="Paid" FontSize="12" TextColor="#6b7280">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFilterPaid" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                    <Border x:Name="TabPending" BackgroundColor="#111f38"
                            Stroke="#1e3a5f" StrokeThickness="1"
                            StrokeShape="RoundRectangle 20" Padding="14,6">
                        <Label Text="Pending" FontSize="12" TextColor="#6b7280">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFilterPending" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                    <Border x:Name="TabOverdue" BackgroundColor="#111f38"
                            Stroke="#1e3a5f" StrokeThickness="1"
                            StrokeShape="RoundRectangle 20" Padding="14,6">
                        <Label Text="Overdue" FontSize="12" TextColor="#6b7280">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFilterOverdue" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>
        </VerticalStackLayout>

        <!-- Invoice List -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="InvoiceList" Padding="16,0,16,16" Spacing="8">
                <ActivityIndicator x:Name="Loading"
                                   IsRunning="True" IsVisible="True"
                                   Color="#c8e63c" Margin="0,20" />

                <!-- Create Button -->
                <Border BackgroundColor="#c8e63c"
                        StrokeShape="RoundRectangle 16"
                        Stroke="Transparent"
                        Margin="0,8,0,0">
                    <Label Text="+ Create New Invoice"
                           FontSize="15" FontAttributes="Bold"
                           TextColor="#000000"
                           HorizontalOptions="Center"
                           Padding="0,16">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCreateInvoice" />
                        </Label.GestureRecognizers>
                    </Label>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
