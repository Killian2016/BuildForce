<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BuildForce.Views.ProjectCreatePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#eef1f8">

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,40" Spacing="12">

            <Border BackgroundColor="White" Stroke="Transparent"
                    StrokeShape="RoundRectangle 16" Padding="0">
                <Border.Shadow>
                    <Shadow Brush="#1a2340" Offset="0,2" Radius="10" Opacity="0.08" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">
                    <Grid HeightRequest="5">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#f0a500" Offset="0.0" />
                                <GradientStop Color="#0ea5e9" Offset="0.5" />
                                <GradientStop Color="#10b981" Offset="1.0" />
                            </LinearGradientBrush>
                        </Grid.Background>
                    </Grid>
                    <VerticalStackLayout Padding="18,14,18,16" Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="OPERATIONS  &#x203A;  PROJECTS"
                                   FontSize="10" FontAttributes="Bold"
                                   TextColor="#8a93a8" CharacterSpacing="2"
                                   VerticalOptions="Center" />
                            <Border Grid.Column="1"
                                    BackgroundColor="#eef1f8" Stroke="#d8deeb" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 18" Padding="12,6">
                                <Label Text="Cancel" FontSize="12" FontAttributes="Bold"
                                       TextColor="#1a2340" />
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCancel" />
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                        <Label Text="Create New Project"
                               FontSize="22" FontAttributes="Bold" TextColor="#1a2340" />
                        <Label Text="Set up a new construction project for an existing customer"
                               FontSize="12" TextColor="#6b7280" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Stroke="#e2e7f0" StrokeThickness="1"
                    StrokeShape="RoundRectangle 14" Padding="16,14">
                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="6">
                        <Label Text="CUSTOMER *" FontSize="10" FontAttributes="Bold"
                               TextColor="#8a93a8" CharacterSpacing="1" />
                        <Border BackgroundColor="White" Stroke="#d8deeb" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10" Padding="6,0">
                            <Picker x:Name="CustomerPicker" Title="&#8212; Select Customer &#8212;"
                                    TextColor="#1a2340" TitleColor="#9aa3b8"
                                    BackgroundColor="Transparent" Margin="8,0" />
                        </Border>
                        <Label Text="Customers are managed on the web at mezanocm.com."
                               FontSize="10" TextColor="#8a93a8" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="PROJECT NAME *" FontSize="10" FontAttributes="Bold"
                               TextColor="#8a93a8" CharacterSpacing="1" />
                        <Border BackgroundColor="White" Stroke="#d8deeb" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10" Padding="12,2">
                            <Entry x:Name="NameEntry"
                                   Placeholder="e.g. Main St Kitchen Remodel"
                                   PlaceholderColor="#9aa3b8" TextColor="#1a2340"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="DESCRIPTION" FontSize="10" FontAttributes="Bold"
                               TextColor="#8a93a8" CharacterSpacing="1" />
                        <Border BackgroundColor="White" Stroke="#d8deeb" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10" Padding="12,8">
                            <Editor x:Name="DescriptionEditor"
                                    Placeholder="Scope of work, notes, anything useful..."
                                    PlaceholderColor="#9aa3b8" TextColor="#1a2340"
                                    BackgroundColor="Transparent"
                                    MinimumHeightRequest="72" AutoSize="TextChanges" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="JOB SITE LOCATION" FontSize="10" FontAttributes="Bold"
                               TextColor="#8a93a8" CharacterSpacing="1" />
                        <Border BackgroundColor="White" Stroke="#d8deeb" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10" Padding="12,2">
                            <Entry x:Name="LocationEntry"
                                   Placeholder="Street address or site description"
                                   PlaceholderColor="#9aa3b8" TextColor="#1a2340"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6" Grid.Column="0">
                            <Label Text="STATUS" FontSize="10" FontAttributes="Bold"
                                   TextColor="#8a93a8" CharacterSpacing="1" />
                            <Border BackgroundColor="White" Stroke="#d8deeb" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10" Padding="6,0">
                                <Picker x:Name="StatusPicker"
                                        TextColor="#1a2340" TitleColor="#9aa3b8"
                                        BackgroundColor="Transparent" Margin="8,0" />
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="6" Grid.Column="1">
                            <Label Text="BUDGET" FontSize="10" FontAttributes="Bold"
                                   TextColor="#8a93a8" CharacterSpacing="1" />
                            <Border BackgroundColor="White" Stroke="#d8deeb" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10" Padding="12,2">
                                <Entry x:Name="BudgetEntry" Placeholder="0.00"
                                       Keyboard="Numeric" PlaceholderColor="#9aa3b8"
                                       TextColor="#1a2340" BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6" Grid.Column="0">
                            <Label Text="START DATE" FontSize="10" FontAttributes="Bold"
                                   TextColor="#8a93a8" CharacterSpacing="1" />
                            <Border BackgroundColor="White" Stroke="#d8deeb" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10" Padding="12,2">
                                <DatePicker x:Name="StartDatePicker" TextColor="#1a2340"
                                            BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="6" Grid.Column="1">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                <CheckBox x:Name="EndDateCheck" Color="#0d7a4f"
                                          VerticalOptions="Center"
                                          CheckedChanged="OnEndDateToggle" />
                                <Label Text="SET END DATE" FontSize="10" FontAttributes="Bold"
                                       TextColor="#8a93a8" CharacterSpacing="1"
                                       VerticalOptions="Center" Grid.Column="1" />
                            </Grid>
                            <Border BackgroundColor="White" Stroke="#d8deeb" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10" Padding="12,2">
                                <DatePicker x:Name="EndDatePicker" TextColor="#1a2340"
                                            BackgroundColor="Transparent" IsEnabled="False" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <Label x:Name="StatusLabel" Text="" FontSize="12"
                   TextColor="#b45309" HorizontalOptions="Center" IsVisible="False" />

            <Border x:Name="SaveBtn" BackgroundColor="#f0a500" Stroke="Transparent"
                    StrokeShape="RoundRectangle 12" Padding="0,15">
                <Border.Shadow>
                    <Shadow Brush="#f0a500" Offset="0,4" Radius="12" Opacity="0.3" />
                </Border.Shadow>
                <Label Text="Create Project" FontSize="15" FontAttributes="Bold"
                       TextColor="#1a1a1a" HorizontalOptions="Center" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSave" />
                </Border.GestureRecognizers>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>