<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BuildForce.Views.DashboardPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#eef1f8">

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,24" Spacing="12">

            <Border BackgroundColor="White" Stroke="Transparent"
                    StrokeShape="RoundRectangle 16" Padding="0">
                <Border.Shadow>
                    <Shadow Brush="#1a2340" Offset="0,2" Radius="10" Opacity="0.08" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">
                    <Grid HeightRequest="5">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#f0a500" Offset="0.0" />
                                <GradientStop Color="#0ea5e9" Offset="0.5" />
                                <GradientStop Color="#10b981" Offset="1.0" />
                            </LinearGradientBrush>
                        </Grid.Background>
                    </Grid>
                    <VerticalStackLayout Padding="18,14,18,16" Spacing="4">
                        <Label Text="COMMAND CENTER" FontSize="10" FontAttributes="Bold"
                               TextColor="#8a93a8" CharacterSpacing="2" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Label x:Name="WelcomeLabel" Text="Welcome back"
                                   FontSize="20" FontAttributes="Bold" TextColor="#1a2340"
                                   LineBreakMode="TailTruncation" VerticalOptions="Center" />
                            <Label x:Name="TimerLabel" Text="00:00:00"
                                   FontSize="13" FontAttributes="Bold" TextColor="#0284c7"
                                   VerticalOptions="Center" Grid.Column="1" />
                        </Grid>
                        <Label x:Name="DateLabel" Text="" FontSize="12" TextColor="#6b7280" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator x:Name="Loading" IsRunning="True" IsVisible="True"
                               Color="#f0a500" Margin="0,8" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Border Grid.Column="0" BackgroundColor="White" Stroke="#e2e7f0" StrokeThickness="1"
                        StrokeShape="RoundRectangle 14" Padding="14,12">
                    <VerticalStackLayout Spacing="3">
                        <Label Text="REVENUE" FontSize="9" FontAttributes="Bold"
                               TextColor="#8a93a8" CharacterSpacing="1" />
                        <Label x:Name="RevenueLabel" Text="$0" FontSize="21" FontAttributes="Bold"
                               TextColor="#0d7a4f" />
                        <Label x:Name="RevBadge" Text="" FontSize="10" TextColor="#8a93a8" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" BackgroundColor="White" Stroke="#e2e7f0" StrokeThickness="1"
                        StrokeShape="RoundRectangle 14" Padding="14,12">
                    <VerticalStackLayout Spacing="3">
                        <Label Text="OUTSTANDING" FontSize="9" FontAttributes="Bold"
                               TextColor="#8a93a8" CharacterSpacing="1" />
                        <Label x:Name="PendingLabel" Text="$0" FontSize="21" FontAttributes="Bold"
                               TextColor="#b45309" />
                        <Label x:Name="PendBadge" Text="" FontSize="10" TextColor="#8a93a8" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Border Grid.Column="0" BackgroundColor="White" Stroke="#e2e7f0" StrokeThickness="1"
                        StrokeShape="RoundRectangle 14" Padding="14,12">
                    <VerticalStackLayout Spacing="3">
                        <Label Text="EXPENSES" FontSize="9" FontAttributes="Bold"
                               TextColor="#8a93a8" CharacterSpacing="1" />
                        <Label x:Name="ExpensesLabel" Text="$0" FontSize="21" FontAttributes="Bold"
                               TextColor="#b3261e" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" BackgroundColor="White" Stroke="#e2e7f0" StrokeThickness="1"
                        StrokeShape="RoundRectangle 14" Padding="14,12">
                    <VerticalStackLayout Spacing="3">
                        <Label Text="NET PROFIT" FontSize="9" FontAttributes="Bold"
                               TextColor="#8a93a8" CharacterSpacing="1" />
                        <Label x:Name="ProfitLabel" Text="$0" FontSize="21" FontAttributes="Bold"
                               TextColor="#1a2340" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border BackgroundColor="White" Stroke="#e2e7f0" StrokeThickness="1"
                    StrokeShape="RoundRectangle 14" Padding="16,14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="QUICK ACTIONS" FontSize="10" FontAttributes="Bold"
                           TextColor="#8a93a8" CharacterSpacing="1" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                          ColumnSpacing="10" RowSpacing="10">
                        <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#f0a500"
                                Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="0,14">
                            <Label Text="+ Invoice" FontSize="13" FontAttributes="Bold"
                                   TextColor="#1a1a1a" HorizontalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNewInvoice" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" BackgroundColor="White"
                                Stroke="#f0a500" StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 12" Padding="0,14">
                            <Label Text="+ Estimate" FontSize="13" FontAttributes="Bold"
                                   TextColor="#b57c00" HorizontalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNewEstimate" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0" BackgroundColor="White"
                                Stroke="#0ea5e9" StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 12" Padding="0,14">
                            <Label Text="+ Project" FontSize="13" FontAttributes="Bold"
                                   TextColor="#0284c7" HorizontalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNewProject" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" BackgroundColor="White"
                                Stroke="#10b981" StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 12" Padding="0,14">
                            <Label Text="+ Expense" FontSize="13" FontAttributes="Bold"
                                   TextColor="#0d7a4f" HorizontalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLogExpense" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Stroke="#e2e7f0" StrokeThickness="1"
                    StrokeShape="RoundRectangle 14" Padding="16,14">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="RECENT PROJECTS" FontSize="10" FontAttributes="Bold"
                               TextColor="#8a93a8" CharacterSpacing="1" VerticalOptions="Center" />
                        <Label Text="View all &#x2192;" FontSize="11" FontAttributes="Bold"
                               TextColor="#0284c7" Grid.Column="1" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnViewAllProjects" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                    <VerticalStackLayout x:Name="ProjectsList" Spacing="8" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>